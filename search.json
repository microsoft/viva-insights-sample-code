---
layout: null
permalink: /search.json
---
{%- assign items = site.html_pages | where_exp: "p", "p.title" | where_exp: "p", "p.search_exclude != true" -%}
[
{%- for p in items -%}
  {
    "title": {{ p.title | jsonify }},
    "url": {{ p.url | relative_url | jsonify }},
    "description": {{ p.description | default: "" | jsonify }},
    "content": {{ p.content | split: "</nav>" | last | strip_html | normalize_whitespace | truncatewords: 500 | jsonify }}
  }{%- unless forloop.last -%},{%- endunless -%}
{%- endfor -%}
]
