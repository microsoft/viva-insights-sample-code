# History files
.Rhistory
.Rapp.history

# Session Data files
.RData

# User-specific files
.Ruserdata

# Example code in package build process
*-Ex.R

# Output files from R CMD build
/*.tar.gz

# Output files from R CMD check
/*.Rcheck/

# RStudio files
.Rproj.user/
*.Rproj

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# OAuth2 token, see https://github.com/hadley/httr/releases/tag/v0.3
.httr-oauth

# knitr and R markdown default cache directories
*_cache/
/cache/

# Temporary files created by R markdown or Jupyter
*.utf8.md
*.knit.md
*.ipynb_checkpoints/

# R Environment Variables
.Renviron

# Rendered HTML output
# Jekyll's own build output is ignored via _site/ below, and package vignettes
# via vignettes/*.html above. We intentionally do NOT blanket-ignore *.html, so
# that the published example outputs under examples/ (linked from the docs) are
# tracked. Ignore only the specific rendered HTML that should not be committed:
examples/network_g2g 1.html
examples/utility-python/causal-inference/did-itsa/*.html

# Data files
examples/utility-r/_data/*.csv

# Output files
examples/utility-python/causal-inference/copilot-causal-toolkit/output/*

# Jekyll build artifacts
_site/
.jekyll-cache/
.jekyll-metadata
Gemfile.lock

# Local-only source decks and documents (do not publish)
assets/decks/
*.pptx
*.docx